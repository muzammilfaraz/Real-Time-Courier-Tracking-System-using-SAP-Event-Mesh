    lineItem:       [ { position: 10, label: 'Log Seq. No.' } ], 
    identification: [ { position: 10, label: 'Log Seq. No.' } ] 
  }
  TrackingId;

  @UI: { 
    lineItem:       [ { position: 20, label: 'Scan Location' } ], 
    identification: [ { position: 20, label: 'Scan Location' } ] 
  }
  ScanLocation;

  @UI: { 
    lineItem:       [ { position: 30, label: 'Event Description' } ], 
