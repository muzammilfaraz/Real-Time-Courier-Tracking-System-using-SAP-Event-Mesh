    typeNamePlural: 'Tracking History', 
    title: { type: #STANDARD, value: 'ScanLocation' },
    description: { type: #STANDARD, value: 'EventDescription' }
  }
}
annotate view ZCIT_C_TRK_22AD067 with
{
  @UI.facet: [
    { 
      id: 'LogInfo', 
      purpose: #STANDARD, 
      type: #IDENTIFICATION_REFERENCE, 
      label: 'Scan Details', 
      position: 10 
    }
